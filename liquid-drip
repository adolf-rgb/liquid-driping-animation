<!DOCTYPE html>
<html>
<head>
  <title>A13-Drip Bootstrap</title>
  <link href="assets/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      margin:0;
      min-height:100vh;
      background:#000;
      display:flex;
      flex-wrap:wrap;
      justify-content:center;
      align-items:center;
      gap:20px;
    }
    .c {
      position:relative;
      width:90vw;
      max-width:400px;
      height:300px;
      background:#000;
      filter:contrast(30);
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      align-items:center;
      padding:20px;
    }
    .b {
      width:70vw;
      max-width:280px;
      height:45px;
      background:#fff;
      border-radius:20px;
      filter:blur(9px);
    }
    .d {
      position:absolute;
      top:10px;
      left:50%;
      width:45px;
      height:45px;
      background:#fff;
      border-radius:50%;
      filter:blur(12px);
      transform:translateX(-50%);
      animation:drop 3s infinite cubic-bezier(.6,.1,.8,.4);
    }
    @keyframes drop {
      25% {top:50px; opacity:1}
      75% {top:210px; opacity:1}
      100% {top:250px; opacity:0}
    }
  </style>
</head>
<body>

  <div class="c"><div class="b"></div><div class="d"></div><div class="b"></div></div>
  <div class="c"><div class="b"></div><div class="d"></div><div class="b"></div></div>
  <div class="c"><div class="b"></div><div class="d"></div><div class="b"></div></div>

</body>
</html>
